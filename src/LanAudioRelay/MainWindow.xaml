<Window x:Class="LanAudioRelay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LAN Audio Relay"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        Background="#F5F7FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="LAN Audio Relay"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="#1D2733" />
            <TextBlock Text="Windows system audio streaming over local network"
                       Margin="0,4,0,0"
                       Foreground="#637083" />
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Sender">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Receiver"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1D2733" />

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Receivers}"
                                  SelectedItem="{Binding SelectedReceiver}"
                                  DisplayMemberPath="DisplayName" />
                        <Button Grid.Column="1"
                                Content="Search LAN"
                                Margin="8,0,0,0"
                                Command="{Binding DiscoverReceiversCommand}" />
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Manual receiver IP" Foreground="#465466" />
                            <TextBox Text="{Binding ManualReceiverIp, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,5,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Pairing code" Foreground="#465466" />
                            <TextBox Text="{Binding SenderPairingCode, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="6"
                                     Margin="0,5,0,0" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                Margin="0,18,0,0">
                        <Button Content="Start Streaming"
                                Command="{Binding StartSenderCommand}" />
                        <Button Content="Stop"
                                Command="{Binding StopSenderCommand}" />
                    </StackPanel>

                    <Grid Grid.Row="4" Margin="0,22,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="{Binding SenderStatus}"
                                   Foreground="#1D2733"
                                   TextWrapping="Wrap" />
                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                            <TextBlock Text="Input level" Foreground="#465466" />
                            <ProgressBar Value="{Binding InputLevel}"
                                         Maximum="1"
                                         Height="18"
                                         Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Receiver">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Receiver"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1D2733" />

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Local IP" Foreground="#465466" />
                            <TextBox Text="{Binding ReceiverLocalAddress}"
                                     IsReadOnly="True"
                                     Margin="0,5,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Pairing code" Foreground="#465466" />
                            <TextBox Text="{Binding ReceiverPairingCode}"
                                     IsReadOnly="True"
                                     FontSize="18"
                                     FontWeight="SemiBold"
                                     Margin="0,5,0,0" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,18,0,0">
                        <Button Content="Start Receiver"
                                Command="{Binding StartReceiverCommand}" />
                        <Button Content="Stop"
                                Command="{Binding StopReceiverCommand}" />
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Volume" Foreground="#465466" />
                            <Slider Value="{Binding ReceiverVolume, UpdateSourceTrigger=PropertyChanged}"
                                    Minimum="0"
                                    Maximum="1"
                                    TickFrequency="0.1"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Buffered frames" Foreground="#465466" />
                            <TextBlock Text="{Binding ReceiverBufferFrames}"
                                       Margin="0,8,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="4"
                               Text="{Binding ReceiverStatus}"
                               Margin="0,22,0,0"
                               Foreground="#1D2733"
                               TextWrapping="Wrap" />
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2"
                   Text="Ports: UDP 51359 discovery, TCP 51360 control, UDP 51361 audio"
                   Margin="0,12,0,0"
                   Foreground="#637083" />
    </Grid>
</Window>
